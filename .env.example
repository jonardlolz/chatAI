# Server Configuration
PORT=3000
NODE_ENV=development

# LLM Configuration
# Options: ollama (default, free, local), claude (paid), openai (paid)
LLM_PROVIDER=ollama

# Ollama Configuration (https://ollama.ai)
# Download and run locally, models run on your machine - completely free
OLLAMA_MODEL=phi4-mini
OLLAMA_BASE_URL=http://localhost:11434

# Claude Configuration (optional, if using claude provider)
# CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI Configuration (optional, if using openai provider)
# OPENAI_API_KEY=your_openai_api_key_here

# Database Support (users will provide these per request)
# Examples for reference:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=mysql://user:password@localhost:3306/dbname
# DATABASE_URL=sqlite:///path/to/database.db

# Logging
LOG_LEVEL=debug
